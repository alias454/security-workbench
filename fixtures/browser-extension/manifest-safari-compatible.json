{
  "manifest_version": 3,
  "name": "Fixture Safari-Compatible WebExtension",
  "version": "1.0.0",
  "description": "Synthetic WebExtensions fixture limited to common MV3 fields.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.example.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Safari-Compatible Fixture"
  },
  "icons": {
    "128": "icon.png"
  }
}
